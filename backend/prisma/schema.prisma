// Schema do banco de dados do TrainPro.
// Em produção troque o provider para "postgresql" e ajuste a DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// SQLite não suporta enums no Prisma; usamos String com valores controlados na aplicação.
// Role: "TRAINER" | "STUDENT"

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Perfis (um usuário é personal OU aluno)
  trainerProfile TrainerProfile?
  studentProfile StudentProfile?
}

model TrainerProfile {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio        String?
  // Código curto que o personal compartilha para o aluno se vincular.
  inviteCode String? @unique

  students     StudentProfile[]
  workouts     Workout[]
  appointments Appointment[]
  dietPlans    DietPlan[]
}

model StudentProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthDate DateTime?
  goal      String?

  // Vínculo com o personal responsável
  trainerId String?
  trainer   TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: SetNull)

  workouts     Workout[]
  progress     ProgressEntry[]
  appointments Appointment[]
  payments     Payment[]
  workoutLogs  WorkoutLog[]
  dietPlans    DietPlan[]
}

model Workout {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  trainerId String?
  trainer   TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: SetNull)

  exercises WorkoutExercise[]
  logs      WorkoutLog[]
}

model WorkoutExercise {
  id          String  @id @default(cuid())
  name        String
  sets        Int     @default(3)
  reps        String  @default("12") // texto para permitir "8-12", "até a falha", etc.
  weightKg    Float?
  restSeconds Int?
  order       Int     @default(0)

  workoutId String
  workout   Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

model ProgressEntry {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  weightKg     Float?
  bodyFat      Float? // percentual de gordura
  measurements String? // JSON com medidas (cintura, braço, etc.)
  notes        String?

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Appointment {
  // status: "SCHEDULED" | "COMPLETED" | "CANCELED"
  id       String   @id @default(cuid())
  startsAt DateTime
  endsAt   DateTime
  status   String   @default("SCHEDULED")
  notes    String?

  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Payment {
  // status: "PENDING" | "PAID" | "OVERDUE"
  id        String    @id @default(cuid())
  amount    Float
  dueDate   DateTime
  paidAt    DateTime?
  status    String    @default("PENDING")
  notes     String?
  createdAt DateTime      @default(now())

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// Check-in: registro de uma sessão de treino executada pelo aluno,
// com as cargas/repetições que ele realmente fez em cada exercício.
model WorkoutLog {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  workoutId String
  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  entries WorkoutLogEntry[]
}

model WorkoutLogEntry {
  id           String  @id @default(cuid())
  exerciseName String
  setsDone     Int?
  repsDone     String?
  weightKg     Float?
  done         Boolean @default(true)
  order        Int     @default(0)

  logId String
  log   WorkoutLog @relation(fields: [logId], references: [id], onDelete: Cascade)
}

// Plano alimentar montado pelo personal para o aluno.
model DietPlan {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  trainerId String?
  trainer   TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: SetNull)

  meals Meal[]
}

model Meal {
  id          String  @id @default(cuid())
  name        String  // ex.: "Café da manhã"
  time        String? // ex.: "08:00"
  description String  // alimentos / quantidades
  order       Int     @default(0)

  dietPlanId String
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
}
