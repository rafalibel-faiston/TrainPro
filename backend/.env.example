# Conexão com o banco PostgreSQL.
# Local (via docker-compose deste repo):
DATABASE_URL="postgresql://trainpro:trainpro@localhost:5432/trainpro?schema=public"
# No Railway, a variável DATABASE_URL é injetada automaticamente pelo plugin Postgres.

# Porta da API
PORT=4000

# Segredo para assinar os tokens JWT (troque por um valor forte em produção)
JWT_SECRET="troque-este-segredo-em-producao"

# Tempo de expiração do token
JWT_EXPIRES_IN="7d"

# Origem permitida para CORS (frontend web)
WEB_ORIGIN="http://localhost:5173"
